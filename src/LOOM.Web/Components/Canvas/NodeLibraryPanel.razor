@using Loom.Api
@inject ILoomApiClient Api

<div class="library-panel">
<div class="library-search">
    <span class="library-search-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7" /><path d="m20 20-3.5-3.5" /></svg>
    </span>
    <input type="text"
           placeholder="Search nodes..."
           @bind="_filter"
           @bind:event="oninput" />
</div>

<div class="library-body" id="libraryBody">
    @if (_loading)
    {
        <p class="library-status">Loading node types…</p>
    }
    else if (_error is not null)
    {
        <p class="library-status library-status-error">@_error</p>
    }
    else
    {
        @foreach (var group in FilteredTypes.GroupBy(t => t.Category).OrderBy(g => g.Key))
        {
            <div class="library-category">
                <div class="library-category-label">@group.Key</div>
                @foreach (var def in group.OrderBy(t => t.Type))
                {
                    <div class="library-item"
                         draggable="true"
                         data-type="@def.Type">
                        <span class="swatch @def.Color"></span>
                        <div class="item-info">
                            <div class="item-name">@CanvasNodeCatalog.GetDisplayName(def.Type)</div>
                            <div class="item-desc">@def.Description</div>
                        </div>
                    </div>
                }
            </div>
        }
    }
</div>
</div>

@code {
    private readonly List<NodeTypeDefinitionDto> _types = [];
    private string _filter = "";
    private bool _loading = true;
    private string? _error;

    private IEnumerable<NodeTypeDefinitionDto> FilteredTypes
    {
        get
        {
            if (string.IsNullOrWhiteSpace(_filter))
                return _types;

            var q = _filter.Trim();
            return _types.Where(t =>
                t.Type.Contains(q, StringComparison.OrdinalIgnoreCase)
                || t.Description.Contains(q, StringComparison.OrdinalIgnoreCase)
                || t.Category.Contains(q, StringComparison.OrdinalIgnoreCase));
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var types = await Api.GetNodeTypesAsync();
            _types.Clear();
            _types.AddRange(types);
        }
        catch (Exception ex)
        {
            _error = "Could not load node types from the server.";
            System.Diagnostics.Debug.WriteLine(ex);
        }
        finally
        {
            _loading = false;
        }
    }

}
