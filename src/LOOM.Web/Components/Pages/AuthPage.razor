@page "/login"
@page "/signup"
@layout LandingLayout
@rendermode InteractiveServer
@inject AuthService Auth
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject AuthTokenStore TokenStore
@implements IDisposable

<PageTitle>LOOM — @(_isSignup ? "Create Account" : "Sign In")</PageTitle>

<LoomMarkSymbol />
<BackgroundEffects />

<div class="auth-page @(_isSignup ? "auth-signup" : "auth-login") @(_ready ? "is-ready" : "") @(_shellReady ? "shell-ready" : "")">
    <div class="auth-split">
        <div class="auth-deco">
            <AuthDemoPanel SpeedMultiplier="@_demoSpeed" />
        </div>

        <div class="auth-form-panel">
            <div class="auth-form-inner @_formSlideClass">
                <AuthBrand />

                @if (_isSignup)
                {
                    <h1 class="auth-heading">Create your account</h1>
                    <p class="auth-sub">Start building visual workflows.</p>

                    @if (!string.IsNullOrEmpty(_error))
                    {
                        <div class="auth-error" role="alert" aria-live="polite">
                            <span aria-hidden="true">!</span>
                            @_error
                        </div>
                    }

                    <form @onsubmit="HandleRegister"
                          @onfocusin="OnFormFocusIn"
                          @onfocusout="OnFormFocusOut"
                          class="auth-form"
                          aria-busy="@_isBusy.ToString().ToLowerInvariant()">
                        <div class="auth-field" style="--field-i:0">
                            <svg class="auth-field-icon" viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M12 12a4 4 0 1 0 0-8 4 4 0 0 0 0 8Z" />
                                <path d="M5 20a7 7 0 0 1 14 0" />
                            </svg>
                            <input id="username" type="text" @bind="_username" placeholder=" " autocomplete="username" required minlength="3" />
                            <label for="username">Username</label>
                        </div>

                        <div class="auth-field" style="--field-i:1">
                            <svg class="auth-field-icon" viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M4 6.5h16v11H4z" />
                                <path d="m4.5 7 7.5 6 7.5-6" />
                            </svg>
                            <input id="email" type="email" @bind="_email" placeholder=" " autocomplete="email" required />
                            <label for="email">Email</label>
                        </div>

                        <div class="auth-field" style="--field-i:2">
                            <svg class="auth-field-icon" viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M7 10V8a5 5 0 0 1 10 0v2" />
                                <path d="M6 10h12v9H6z" />
                            </svg>
                            <input id="password" type="password" @bind="_password" placeholder=" " autocomplete="new-password" required minlength="6" />
                            <label for="password">Password</label>
                        </div>

                        <button type="submit" class="auth-btn" disabled="@_isBusy">
                            @if (_isBusy)
                            {
                                <span class="auth-spinner" aria-label="Creating account"></span>
                            }
                            else
                            {
                                <span>Create account</span>
                            }
                        </button>
                    </form>

                    <div class="auth-or-divider"><span>or</span></div>

                    <button type="button" class="auth-google-btn" onclick="window.location.href='/api/auth/google-login'">
                        <svg class="auth-google-icon" viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
                        Continue with Google
                    </button>

                    <div class="auth-oauth-github">
                        <button type="button" class="auth-github-btn" onclick="window.location.href='/api/auth/github-login'">
                            <svg class="auth-github-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.387.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.73.083-.73 1.205.085 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 21.795 24 17.295 24 12 24 5.37 18.63 0 12 0z"/></svg>
                            Continue with GitHub
                        </button>
                    </div>

                    <div class="auth-footer">
                        <span>Already have an account?</span>
                        <NavLink href="/login" class="auth-route-link">Sign in</NavLink>
                        <span class="auth-footer-sep">/</span>
                        <NavLink href="/" class="auth-route-link">Back to home</NavLink>
                    </div>
                }
                else
                {
                    <h1 class="auth-heading">Welcome back</h1>
                    <p class="auth-sub">Sign in to open the canvas editor.</p>

                    @if (!string.IsNullOrEmpty(_error))
                    {
                        <div class="auth-error" role="alert" aria-live="polite">
                            <span aria-hidden="true">!</span>
                            @_error
                        </div>
                    }

                    <form @onsubmit="HandleLogin"
                          @onfocusin="OnFormFocusIn"
                          @onfocusout="OnFormFocusOut"
                          class="auth-form"
                          aria-busy="@_isBusy.ToString().ToLowerInvariant()">
                        <div class="auth-field" style="--field-i:0">
                            <svg class="auth-field-icon" viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M4 6.5h16v11H4z" />
                                <path d="m4.5 7 7.5 6 7.5-6" />
                            </svg>
                            <input id="email" type="email" @bind="_email" placeholder=" " autocomplete="email" required />
                            <label for="email">Email</label>
                        </div>

                        <div class="auth-field" style="--field-i:1">
                            <svg class="auth-field-icon" viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M7 10V8a5 5 0 0 1 10 0v2" />
                                <path d="M6 10h12v9H6z" />
                            </svg>
                            <input id="password" type="password" @bind="_password" placeholder=" " autocomplete="current-password" required />
                            <label for="password">Password</label>
                        </div>

                        <button type="submit" class="auth-btn" disabled="@_isBusy">
                            @if (_isBusy)
                            {
                                <span class="auth-spinner" aria-label="Signing in"></span>
                            }
                            else
                            {
                                <span>Sign in</span>
                            }
                        </button>
                    </form>

                    <div class="auth-or-divider"><span>or</span></div>

                    <button type="button" class="auth-google-btn" onclick="window.location.href='/api/auth/google-login'">
                        <svg class="auth-google-icon" viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
                        Continue with Google
                    </button>

                    <div class="auth-oauth-github">
                        <button type="button" class="auth-github-btn" onclick="window.location.href='/api/auth/github-login'">
                            <svg class="auth-github-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.387.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.73.083-.73 1.205.085 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 21.795 24 17.295 24 12 24 5.37 18.63 0 12 0z"/></svg>
                            Continue with GitHub
                        </button>
                    </div>

                    <div class="auth-footer">
                        <span>No account yet?</span>
                        <NavLink href="/signup" class="auth-route-link">Create one</NavLink>
                        <span class="auth-footer-sep">/</span>
                        <NavLink href="/" class="auth-route-link">Back to home</NavLink>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private string _username = string.Empty;
    private string _email = string.Empty;
    private string _password = string.Empty;
    private string _error = string.Empty;
    private bool _isBusy;
    private bool _ready;
    private bool _shellReady;
    private bool _isSignup;
    private string _formSlideClass = string.Empty;
    private double _demoSpeed = 1;
    private CancellationTokenSource? _slideCts;

    protected override void OnInitialized()
    {
        Nav.LocationChanged += OnLocationChanged;
        SyncRoute();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        if (!_isSignup && Auth.IsLoggedIn)
        {
            Nav.NavigateTo("/canvas");
            return;
        }

        await Task.Delay(16);
        _ready = true;
        _shellReady = true;
        StateHasChanged();
        await JS.InvokeVoidAsync("loomAuth.initPage", ".auth-page .auth-split", ".auth-page .auth-deco");
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        var wasSignup = _isSignup;
        SyncRoute();
        _error = string.Empty;

        if (_shellReady && wasSignup != _isSignup)
        {
            _slideCts?.Cancel();
            _slideCts = new CancellationTokenSource();
            _formSlideClass = _isSignup ? "slide-from-right" : "slide-from-left";
            _ = ClearSlideClassAsync(_slideCts.Token);
        }

        InvokeAsync(StateHasChanged);
    }

    private async Task ClearSlideClassAsync(CancellationToken cancellationToken)
    {
        try
        {
            await Task.Delay(520, cancellationToken);
            _formSlideClass = string.Empty;
            await InvokeAsync(StateHasChanged);
        }
        catch (OperationCanceledException)
        {
            /* superseded by another switch */
        }
    }

    private void SyncRoute()
    {
        var path = Nav.ToBaseRelativePath(Nav.Uri).TrimEnd('/');
        _isSignup = path.Equals("signup", StringComparison.OrdinalIgnoreCase);
    }

    private void OnFormFocusIn() => _demoSpeed = 0.65;

    private void OnFormFocusOut() => _demoSpeed = 1;

    private async Task HandleLogin()
    {
        _error = string.Empty;
        _isBusy = true;

        try
        {
            var (success, username, error) = await Auth.TryLoginAsync(_email, _password);
            if (success)
            {
                await JS.InvokeVoidAsync("loomAuth.flashSuccess", ".auth-login .auth-btn");
                await Task.Delay(220);
                var token = TokenStore.Generate(username!);
                Nav.NavigateTo($"/api/auth/apply?token={token}", forceLoad: true);
            }
            else
            {
                _error = error;
            }
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task HandleRegister()
    {
        _error = string.Empty;
        _isBusy = true;

        try
        {
            var (success, error) = await Auth.TryRegisterAsync(_username, _email, _password);
            if (success)
            {
                await JS.InvokeVoidAsync("loomAuth.flashSuccess", ".auth-signup .auth-btn");
                await Task.Delay(220);
                var token = TokenStore.Generate(_username);
                Nav.NavigateTo($"/api/auth/apply?token={token}", forceLoad: true);
            }
            else
            {
                _error = error;
            }
        }
        finally
        {
            _isBusy = false;
        }
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
        _slideCts?.Cancel();
        _slideCts?.Dispose();
    }
}
