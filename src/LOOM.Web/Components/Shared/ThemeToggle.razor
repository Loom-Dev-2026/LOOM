@inject IJSRuntime JS
@inject ThemeService ThemeService
@implements IDisposable

<button type="button" class="theme-toggle" @onclick="ToggleThemeAsync" aria-label="Toggle light/dark mode" id="@ElementId">
    <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4" /><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41" /></svg>
    <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" /></svg>
</button>

@code {
    [Parameter] public string? ElementId { get; set; }

    private IJSObjectReference? _themeModule;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _themeModule is not null)
            return;

        _themeModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/theme.js");
        var theme = await _themeModule.InvokeAsync<string>("getTheme");
        ThemeService.SetTheme(theme);
    }

    private async Task ToggleThemeAsync()
    {
        if (_themeModule is null)
            _themeModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/theme.js");

        var theme = await _themeModule.InvokeAsync<string>("toggleTheme");
        ThemeService.SetTheme(theme);
    }

    public void Dispose() => _ = _themeModule?.DisposeAsync();
}
