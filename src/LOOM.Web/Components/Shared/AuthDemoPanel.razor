@implements IAsyncDisposable
@using LOOM.Web.Models
@inject IJSRuntime JS

<div class="loom-auth-demo @RootClasses" id="authDemoPanel" aria-hidden="true">
    <div class="loom-demo-frame">
        <header class="loom-demo-chrome">
            <div class="loom-demo-traffic">
                <span></span><span></span><span></span>
            </div>
            <strong class="loom-demo-title">HelloWorld.loom</strong>
            <button type="button"
                    class="loom-demo-run @(_runPressed || _runExecuting ? "is-executing" : "") @(_runPressed ? "is-pressed" : "") @(_hideRunButton ? "is-hidden" : "")"
                    tabindex="-1">
                <svg class="loom-demo-run-icon" viewBox="0 0 24 24" aria-hidden="true">
                    <polygon points="6 4 20 12 6 20" />
                </svg>
                <span>@(_runExecuting ? "Running" : "Run")</span>
            </button>
        </header>

        <div class="loom-demo-stage">
            <div class="loom-demo-canvas @(_showCode ? "is-fading" : "") @(_resetting ? "is-resetting" : "")" id="loomDemoCanvas">
                <svg class="loom-demo-edge" aria-hidden="true">
                    <path class="loom-demo-edge-base" d="" />
                    <path class="loom-demo-edge-flow" d="" />
                </svg>

                <article class="loom-demo-node loom-demo-node--input @InputClasses">
                    <div class="loom-demo-node-head">
                        <span class="loom-demo-badge"></span>
                        <strong class="loom-demo-node-name">String input</strong>
                        <span class="loom-demo-node-status">@InputStatusLabel</span>
                    </div>
                    <div class="loom-demo-node-value">Hello World</div>
                    <span class="loom-demo-port loom-demo-port--out"></span>
                </article>

                <article class="loom-demo-node loom-demo-node--output @OutputClasses">
                    <div class="loom-demo-node-head">
                        <span class="loom-demo-badge"></span>
                        <strong class="loom-demo-node-name">Answer</strong>
                        <span class="loom-demo-node-status">@OutputStatusLabel</span>
                    </div>
                    <div class="loom-demo-node-value">Hello World</div>
                    <span class="loom-demo-port loom-demo-port--in"></span>
                </article>
            </div>

            <div class="loom-demo-editor @(_showCode ? "is-visible" : "") @(_resetting ? "is-resetting" : "")">
                <div class="loom-demo-editor-header">
                    <span>Generated C#</span>
                    <em>hello-world.cs</em>
                </div>
                <pre class="loom-demo-editor-body"><code>
@foreach (var (line, index) in _codeLines.Select((l, i) => (l, i)))
{
                    <span class="loom-demo-code-line @(_visibleCodeLines > index ? "is-visible" : "")">@((MarkupString)line)</span>
}
                </code></pre>
                <div class="loom-demo-terminal @(_visibleCodeLines >= _codeLines.Length ? "is-visible" : "")">
                    <span>Output</span>
                    <strong>Hello World</strong>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public AuthDemoTiming Timing { get; set; } = new();
    [Parameter] public double SpeedMultiplier { get; set; } = 1;

    private CancellationTokenSource? _cts;
    private bool _showInput;
    private bool _showOutput;
    private bool _edgeDrawing;
    private bool _edgeDrawn;
    private bool _runPressed;
    private bool _runExecuting;
    private bool _inputRunning;
    private bool _inputSuccess;
    private bool _edgePulsing;
    private bool _outputRunning;
    private bool _outputSuccess;
    private bool _showCode;
    private bool _hideRunButton;
    private bool _resetting;
    private int _visibleCodeLines;

    private readonly string[] _codeLines =
    [
        """<span class="kw">// Generated by LOOM</span>""",
        """<span class="kw">// HelloWorld.loom</span>""",
        """<span class="kw">&nbsp;</span>""",
        """<span class="type">string</span> <span class="var">a</span> = <span class="str">"Hello World"</span>;""",
        """<span class="type">string</span> <span class="var">answer</span> = <span class="var">a</span>;""",
        """Console.WriteLine(<span class="var">answer</span>);""",
        """<span class="kw">// Output: Hello World</span>"""
    ];

    private string RootClasses => string.Join(" ",
        _edgeDrawing ? "is-edge-drawing" : "",
        _edgeDrawn ? "is-edge-drawn" : "",
        _edgePulsing ? "is-edge-pulsing" : "",
        SpeedMultiplier < 1 ? "is-fast" : "");

    private string InputClasses => string.Join(" ",
        _showInput ? "is-visible" : "",
        _inputRunning ? "is-running" : "",
        _inputSuccess ? "is-success" : "");

    private string OutputClasses => string.Join(" ",
        _showOutput ? "is-visible" : "",
        _outputRunning ? "is-running" : "",
        _outputSuccess ? "is-success" : "");

    private string InputStatusLabel => _inputSuccess ? "done" : _inputRunning ? "running" : "idle";
    private string OutputStatusLabel => _outputSuccess ? "done" : _outputRunning ? "running" : "idle";

    protected override void OnInitialized()
    {
        _cts = new CancellationTokenSource();
        _ = RunLoopAsync(_cts.Token);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await JS.InvokeVoidAsync("loomAuth.initDemoEdge", "#authDemoPanel");
        else
            await JS.InvokeVoidAsync("loomAuth.updateDemoEdge", "#authDemoPanel");
    }

    private async Task RunLoopAsync(CancellationToken ct)
    {
        await Task.Yield();

        while (!ct.IsCancellationRequested)
            await RunCycleAsync(ct);
    }

    private async Task RunCycleAsync(CancellationToken ct)
    {
        ResetState();
        await RefreshAsync(ct);
        await Delay(Timing.EmptyHold, ct);

        _showInput = true;
        await RefreshAsync(ct);
        await Delay(Timing.InputSlide, ct);
        await JS.InvokeVoidAsync("loomAuth.updateDemoEdge", "#authDemoPanel");

        _showOutput = true;
        await RefreshAsync(ct);
        await Delay(Timing.OutputSlide, ct);
        await JS.InvokeVoidAsync("loomAuth.updateDemoEdge", "#authDemoPanel");

        _edgeDrawing = true;
        await RefreshAsync(ct);
        await JS.InvokeVoidAsync("loomAuth.updateDemoEdge", "#authDemoPanel");
        await Delay(Timing.EdgeDraw, ct);

        _edgeDrawing = false;
        _edgeDrawn = true;
        await RefreshAsync(ct);
        await Delay(Timing.LinkGlow, ct);

        _runPressed = true;
        await RefreshAsync(ct);
        await Delay(Timing.RunPress, ct);

        _runPressed = false;
        _runExecuting = true;
        _inputRunning = true;
        await RefreshAsync(ct);
        await Delay(Timing.InputExecute, ct);

        _inputRunning = false;
        _inputSuccess = true;
        await RefreshAsync(ct);
        await Delay(Timing.InputSuccess, ct);

        _edgePulsing = true;
        await RefreshAsync(ct);
        await Delay(Timing.EdgePulse, ct);

        _edgePulsing = false;
        _outputRunning = true;
        await RefreshAsync(ct);
        await Delay(Timing.OutputExecute, ct);

        _outputRunning = false;
        _outputSuccess = true;
        await RefreshAsync(ct);
        await Delay(Timing.OutputSuccess, ct);

        _runExecuting = false;
        _hideRunButton = true;
        _showCode = true;
        await RefreshAsync(ct);
        await JS.InvokeVoidAsync("loomAuth.updateDemoEdge", "#authDemoPanel");
        await Delay(Timing.ToCode, ct);

        for (var i = 1; i <= _codeLines.Length; i++)
        {
            _visibleCodeLines = i;
            await RefreshAsync(ct);
            await Delay(Timing.CodeLine, ct);
        }

        await Delay(Timing.CodeHold, ct);

        _resetting = true;
        await RefreshAsync(ct);
        await Delay(Timing.ResetFade, ct);
    }

    private void ResetState()
    {
        _showInput = false;
        _showOutput = false;
        _edgeDrawing = false;
        _edgeDrawn = false;
        _runPressed = false;
        _runExecuting = false;
        _inputRunning = false;
        _inputSuccess = false;
        _edgePulsing = false;
        _outputRunning = false;
        _outputSuccess = false;
        _showCode = false;
        _hideRunButton = false;
        _resetting = false;
        _visibleCodeLines = 0;
    }

    private async Task RefreshAsync(CancellationToken ct)
    {
        await InvokeAsync(StateHasChanged);
        if (ct.IsCancellationRequested)
            throw new OperationCanceledException(ct);
    }

    private async Task Delay(int ms, CancellationToken ct)
    {
        if (ms <= 0) return;
        var scaled = Math.Max(80, (int)(ms * SpeedMultiplier));
        await Task.Delay(scaled, ct);
    }

    public async ValueTask DisposeAsync()
    {
        if (_cts is null) return;
        await _cts.CancelAsync();
        _cts.Dispose();
        _cts = null;
    }
}

